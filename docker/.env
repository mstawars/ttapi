# Konfiguracja docker-compose dla TTAPI
# Skopiuj ten plik jako .env i dostosuj do środowiska lokalnego.
# Wszystkie zmienne mają wartości domyślne w docker-compose.yaml,
# więc plik .env jest opcjonalny.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rest_db

# ---------------------------------------------------------------------------
# Keycloak
# ---------------------------------------------------------------------------
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_PORT=8180
